# Docker-first defaults for local workbench development.
# Copy to `.env` only when you want to override ports or credentials.
# Optional: set a separate workspace root for specs/runtime state when modeling
# another repo, for example:
# WORKBENCH_ROOT_DIR=/home/you/projects/real-estate/.data-workbench

WORKBENCH_PORT=8000
WORKBENCH_PERSISTENCE_BACKEND=mirror
WORKBENCH_OBJECT_STORE_BACKEND=minio
WORKBENCH_AUTO_PROFILE=0
WORKBENCH_WORKER_INTERVAL=30
WORKBENCH_PROJECT_PROFILE_ALLOW_PARQUET=0
# WORKBENCH_PROJECT_PROFILE_MAX_ASSET_BYTES=16777216
# WORKBENCH_PROJECT_PROFILE_EXCLUDE_PATHS=raw,warehouse,tmp

POSTGRES_DB=workbench
POSTGRES_USER=workbench
POSTGRES_PASSWORD=workbench
POSTGRES_PORT=5432

MINIO_ROOT_USER=workbench
MINIO_ROOT_PASSWORD=workbench123
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

WORKBENCH_MINIO_ENDPOINT=minio:9000
WORKBENCH_MINIO_ACCESS_KEY=workbench
WORKBENCH_MINIO_SECRET_KEY=workbench123
WORKBENCH_MINIO_BUCKET=workbench-artifacts
WORKBENCH_MINIO_SECURE=0
